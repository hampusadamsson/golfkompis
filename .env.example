# Copy to .env and fill in your credentials. .env is gitignored.

# MinGolf (required for real tee-time calls; per-user creds are stored in the DB for web app users)
MINGOLF_USERNAME=YYMMDD-XXX
MINGOLF_PASSWORD=your-password

# Auth / user management
AUTH_SECRET=change-me-in-production
AUTH_DATABASE_URL=sqlite+aiosqlite:///./users.db
AUTH_COOKIE_SECURE=false
# AUTH_FRONTEND_BASE_URL derives /verify and /reset-password automatically
AUTH_FRONTEND_BASE_URL=http://localhost:5173

# Email — dev default: Mailpit (docker run -p 1025:1025 -p 8025:8025 axllent/mailpit)
MAIL_FROM=noreply@example.com
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_STARTTLS=false
MAIL_SSL_TLS=false
# MAIL_USERNAME=
# MAIL_PASSWORD=

# Email — production: smtp2go (uncomment and fill in)
# MAIL_SERVER=mail.smtp2go.com
# MAIL_PORT=2525
# MAIL_STARTTLS=true
# MAIL_SSL_TLS=false
# MAIL_USERNAME=<smtp2go-username>
# MAIL_PASSWORD=<smtp2go-api-password>
# MAIL_FROM=noreply@yourdomain.tld

# Tee-time search queue (optional overrides)
# QUEUE_ENABLED=true
# QUEUE_POLL_INTERVAL_MINUTES=60
# QUEUE_ACTIVE_WINDOW_START=08:00
# QUEUE_ACTIVE_WINDOW_STOP=23:00
# QUEUE_EMAIL_MAX_SLOTS=20
